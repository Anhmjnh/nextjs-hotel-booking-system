// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  USER
  ADMIN
}

enum RoomType {
  SINGLE
  DOUBLE
  SUITE
  FAMILY
}

enum BookingStatus {
  PENDING     // Vừa đặt, chờ thanh toán
  CONFIRMED   // Đã thanh toán hoặc chốt đặt
  CANCELLED   // Đã hủy (bởi User hoặc Admin, hoặc do quá hạn thanh toán)
  COMPLETED   // Đã check-out và hoàn thành
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  ONLINE
  CASH
}

// --- MODELS ---

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String?   // Bỏ bắt buộc vì Đăng nhập Google không có pass
  googleId  String?   @unique // Lưu ID của Google
  name      String
  phone     String?
  avatar    String?   // Trường lưu link ảnh đại diện
  role      Role      @default(USER)
  
  bookings  Booking[] // Relationship: 1 User có nhiều Booking (Quản lý booking cá nhân)
  passwordResetTokens PasswordResetToken[] // Liên kết đến các token reset mật khẩu
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Room {
  id            Int       @id @default(autoincrement())
  name          String
  description   String    @db.Text
  pricePerNight Float
  capacity      Int       // Số người tối đa
  type          RoomType
  amenities     String[]  // Mảng tiện ích (Wifi, Tivi, Điều hòa...)
  images        String[]  // Mảng URL ảnh của phòng
  location      String    @default("TP. Hồ Chí Minh") // Vị trí phòng (Thành phố/Khu vực)
  isAvailable   Boolean   @default(true) 
  
  bookings      Booking[] 

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Booking {
  id             Int           @id @default(autoincrement())
  userId         Int
  roomId         Int
  
  checkInDate    DateTime
  checkOutDate   DateTime
  totalDays      Int
  totalPrice     Float
  status         BookingStatus @default(PENDING)
  paymentMethod  PaymentMethod @default(ONLINE) // Hình thức TT
  appliedCode    String?       // Mã giảm giá đã áp dụng
  discountAmount Float         @default(0)      // Số tiền được giảm

  guestName      String?       // Tên người nhận phòng
  guestPhone     String?       // Số điện thoại người nhận phòng
  guestCount     Int           @default(1)      // Số lượng người đi

  specialRequest String?       @db.Text

  user           User          @relation(fields: [userId], references: [id])
  room           Room          @relation(fields: [roomId], references: [id])
  payment        Payment?      // 1 Booking có 1 Payment (One-to-One)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Payment {
  id              Int           @id @default(autoincrement())
  bookingId       Int           @unique 
  stripeSessionId String?       @unique 
  amount          Float
  status          PaymentStatus @default(UNPAID)
  paymentDate     DateTime?

  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
model Offer {
  id            Int      @id @default(autoincrement())
  title         String
  code          String   @unique
  discountType  String   // 'PERCENTAGE' (Phần trăm) hoặc 'FIXED' (Tiền mặt)
  discountValue Float
  minOrderValue Float?   // Tùy chọn: Giá trị đơn tối thiểu để áp dụng
  maxDiscount   Float?   // Tùy chọn: Mức giảm tối đa (nếu chọn giảm theo %)
  startDate     DateTime
  endDate       DateTime
  image         String
  color         String?  @default("bg-blue-50 text-blue-700 border-blue-200")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
